# LLM API Keys
DEEPSEEK_API_KEY="sk-xxxxxxxxxxxxxxxx"
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxx"

# LLM Provider Configuration
LLM_PROVIDER="deepseek"  # Options: deepseek, openai
